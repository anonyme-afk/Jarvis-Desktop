# PROVIDER ACTIF (défaut : gemini-2.0-flash)
AI_PROVIDER=gemini-2.0-flash

# ─── CLÉS API ───────────────────────────────
# Google Gemini — GRATUIT sur https://aistudio.google.com
GEMINI_API_KEY=

# Groq — GRATUIT ultra-rapide sur https://console.groq.com
GROQ_API_KEY=

# OpenRouter — accès à TOUS les modèles sur https://openrouter.ai
OPENROUTER_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=

# xAI Grok — https://console.x.ai
XAI_API_KEY=

# Mistral — https://console.mistral.ai
MISTRAL_API_KEY=

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ─── OLLAMA LOCAL ───────────────────────────
OLLAMA_MODEL=AUTO

# ─── NOTIFICATIONS (optionnel) ───────────────
DISCORD_WEBHOOK=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
