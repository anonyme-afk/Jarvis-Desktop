# ============================================================
# JARVIS Desktop — Configuration
# ============================================================

# ---- PROVIDER IA ACTIF ----
# Par défaut : gemini-2.0-flash (gratuit, rapide)
# Options : gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro,
#           gemini-2.5-pro, gemini-2.5-flash,
#           groq-llama4, groq-llama3, groq-llama3-70b,
#           claude-sonnet, claude-haiku, claude-opus,
#           gpt-4o, gpt-4o-mini, gpt-o3-mini,
#           grok-3, mistral-free, deepseek-v3, deepseek-r1,
#           openrouter-auto, or-llama-free, or-deepseek-free, or-qwen-free,
#           ollama-auto
AI_PROVIDER=gemini-2.0-flash

# ---- CLÉS API (mets seulement celles que tu as) ----

# Google Gemini — GRATUIT sur https://aistudio.google.com
GEMINI_API_KEY=

# Groq — GRATUIT ultra-rapide sur https://console.groq.com
GROQ_API_KEY=

# OpenRouter — Accès à TOUS les modèles sur https://openrouter.ai
# Avec une seule clé tu accèdes à GPT, Claude, Llama, Mistral, etc.
OPENROUTER_API_KEY=

# Anthropic Claude — Payant sur https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI GPT — Payant sur https://platform.openai.com
OPENAI_API_KEY=

# xAI Grok — Payant sur https://console.x.ai
XAI_API_KEY=

# Mistral — Gratuit limité sur https://console.mistral.ai
MISTRAL_API_KEY=

# DeepSeek — Très abordable sur https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ---- MODE LOCAL (Ollama) ----
# Installer Ollama sur https://ollama.com
# Puis : ollama pull llama3.2
OLLAMA_MODEL=AUTO

# ---- NOTIFICATIONS (optionnel) ----
DISCORD_WEBHOOK=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ---- OSINT (optionnel) ----
HIBP_API_KEY=
