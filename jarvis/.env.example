# ============================================================
# JARVIS DESKTOP v3.0 — Configuration complète
# ============================================================

# ---- PROVIDER IA ACTIF ----
# Options: gemini-free, gemini-pro, groq-free, mistral-free,
#          claude-sonnet, gpt4o, grok, deepseek, cohere-free, ollama-auto
AI_PROVIDER=gemini-free

# ---- CLÉS API IA (mettre seulement celles que tu as) ----
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# ---- OLLAMA LOCAL ----
OLLAMA_MODEL=AUTO

# ---- NOTIFICATIONS ----
DISCORD_WEBHOOK=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
GOTIFY_URL=
GOTIFY_TOKEN=

# ---- OSINT (optionnel) ----
HIBP_API_KEY=

# ---- DOMOTIQUE ----
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# ---- TÉLÉPHONE ANDROID ----
PHONE_ENABLED=true

# ---- GAMING ----
GAMING_MODE=false
