{
  "name": "jarvis-desktop",
  "version": "1.0.0",
  "description": "JARVIS Desktop Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "install-python": "pip install -r python/requirements.txt",
    "dev": "electron . --inspect"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.jarvis.desktop",
    "productName": "JARVIS",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
